<aside>
  <header>
    <div class="actor">
      {{#if actor}}
      <img src="{{actor.img}}" alt="{{actor.name}}">
      <span><a class="content-link" data-uuid="{{actor.uuid}}" data-link="{{actor.uuid}}" data-type="Actor"><i class="fas fa-user"></i> {{actor.name}}'s</a>Tutor List</span>
      <a data-action="clear" title="Clear Actor"><i class="fas fa-times"></i></a>
      {{else}}
      <p>Viewing All Tutor Data<br><small>Drag an Actor here to view their Tutor List</small></p>
      {{/if}}
    </div>
    <div class="sort-container">
      <label for="sort-by">Sort moves by: </label>
      <select name="sort-by">
        <option value="name" {{#if (eq sortBy "name")}} selected{{/if}}>Name</option>
        <option value="grade" {{#if (eq sortBy "grade")}} selected{{/if}}>Grade</option>
      </select>
    </div>
    <div class="grade-filters">
      <button type="button" class="grade-filter{{#if (includes selectedGrades "S")}} active{{/if}}" data-grade="S">S</button>
      <button type="button" class="grade-filter{{#if (includes selectedGrades "A")}} active{{/if}}" data-grade="A">A</button>
      <button type="button" class="grade-filter{{#if (includes selectedGrades "B")}} active{{/if}}" data-grade="B">B</button>
      <button type="button" class="grade-filter{{#if (includes selectedGrades "C")}} active{{/if}}" data-grade="C">C</button>
      <button type="button" class="grade-filter{{#if (includes selectedGrades "D")}} active{{/if}}" data-grade="D">D</button>
      <button type="button" class="grade-filter{{#if (includes selectedGrades "E")}} active{{/if}}" data-grade="E">E</button>
    </div>

    <input name="filter" type="search" placeholder="Filter" value="">
  </header>
  <nav class="scroll tutor-list-options">
    <a class="item{{#if (eq tab "")}} active{{/if}}" data-tab="">
      All
    </a>
    {{#each lists as |list|}}
      <a class="item list-tab{{#if (eq @root.tab list.slug)}} active{{/if}}" data-tab="{{list.slug}}">
        {{list.title}}
      </a>
    {{/each}}
  </nav>
</aside>