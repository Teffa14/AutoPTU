<section class="tab sheet-body {{tabs.details.cssClass}}" data-tab="details" data-group="sheet">
    <div class="scroll">
        <fieldset>
            <legend>
                Details
            </legend>
            {{#if (devMode)}}
              {{formField fields.slug value=source.system.slug localize=true}}
            {{/if}}
            
            {{formField fields.quantity value=source.system.quantity localize=true}}
            {{formField fields.equipped.fields.carryType value=source.system.equipped.carryType localize=true}}
            {{formField fields.equipped.fields.slot value=source.system.equipped.slot localize=true}}
            {{formField fields.equipped.fields.handsHeld value=source.system.equipped.handsHeld localize=true}}
            {{formField fields.ammoType value=source.system.ammoType localize=true}}
            <div class="form-group">
              <label>{{localize "PTR2E.FIELDS.gear.ammo.label"}}</label>
              <div class="form-fields">
                <select name="system.ammo">
                  <option value="">--</option>
                  {{#each ammoOptions}}
                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </div>
              <p class="hint">{{localize "PTR2E.FIELDS.gear.ammo.hint"}}</p>
            </div>
        </fieldset>
        <fieldset>
            <legend>
                Crafting
            </legend>
            {{formField fields.crafting.fields.skill value=source.system.crafting.skill localize=true}}
            {{formField fields.crafting.fields.spans value=source.system.crafting.spans localize=true}}
            {{formField fields.crafting.fields.materials value=source.system.crafting.materials localize=true}}
            {{formField fields.grade value=source.system.grade localize=true}}
            {{formField fields.rarity value=source.system.rarity localize=true}} 
        </fieldset>
        <fieldset>
            <legend>
                Fling Stats
            </legend>
            {{formField fields.fling.fields.type value=source.system.fling.type localize=true}}
            {{formField fields.fling.fields.power value=source.system.fling.power localize=true}}
            {{formField fields.fling.fields.accuracy value=source.system.fling.accuracy localize=true}} 
            {{formField fields.fling.fields.hide value=source.system.fling.hide localize=true}} 
            {{formField fields.fling.fields.range.fields.target value=source.system.fling.range.target localize=true}} 
            {{formField fields.fling.fields.range.fields.distance value=source.system.fling.range.distance localize=true}}
        </fieldset>
        <fieldset>
            <legend>
                Weapon Fields (Temporary Fields)
            </legend>
            {{formField fields.weaponType value=source.system.weaponType localize=true}}
            {{formField fields.weaponPp value=source.system.weaponPp localize=true}}
            {{formField fields.weaponRange value=source.system.weaponRange localize=true}}
        </fieldset>
        <fieldset>
            <legend>
                Description
            </legend>
            {{formField fields.description enriched=enrichedDescription value=source.system.description toggled=true localize=true}}
        </fieldset>
        <fieldset>
          <legend>
            Publication Details
          </legend>
          {{formField fields.publication.fields.source value=source.system.publication.source localize=true}}
          {{formField fields.publication.fields.authors value=source.system.publication.authors localize=true}}
          {{formField fields.publication.fields.notes enriched=enrichedNotes value=source.system.publication.notes toggled=true localize=true}}
        </fieldset>
    </div>
</section>