<div class="form-group">
    <label>{{localize "PTR2E.FIELDS.clock.id.label"}}</label>
    <div class="form-fields">
      <input type="text" name="{{basePath}}.key" value="{{change.key}}" />
    </div>
</div>

<div class="form-group">
    <label>{{localize "PTR2E.Effect.FIELDS.ChangeValue.label"}}</label>
    <div class="form-fields">
        <input type="text" name="{{basePath}}.value" value="{{change.value}}" />
    </div>
</div>

<div class="form-group">
    <label>{{localize fields.predicate.label}}</label>
    <input type="text" name="{{basePath}}.predicate" value="{{json change.predicate spaces=0}}" />
</div>