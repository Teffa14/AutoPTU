<div class="movement-component">
  <fieldset class="can-popout" data-component="movement">
    <legend>Movement Totals</legend>
    <div class="movement">
      <label class="spacer"></label>
      <label>Score</label>
      <label>Available</label>
    </div>
    {{#each movement}}
      <div class="movement">
        <label>{{formatSlug method}}</label>
        <input type="number" value="{{value}}" disabled>
        <input type="number" value="{{available}}" disabled>
      </div>
    {{/each}}
    <div class="movement">
      <label>Jump</label>
      <input type="number" value="{{jump}}" disabled>
      <span style="flex: 0 0 25%;"></label>
    </div>
  </fieldset>
</div>