root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{js,css,html,json,md,yml,yaml}]
indent_size = 2

[*.bat]
end_of_line = crlf

[*.{png,jpg,jpeg,gif,webp,ico,woff,woff2,ttf,eot,pdf,zip,rar,sqlite3}]
insert_final_newline = false
trim_trailing_whitespace = false
